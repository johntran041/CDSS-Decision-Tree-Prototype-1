      "source": { "reference": "Hình 3", "page": 17 }
    },
    {
      "ruleId": "h3_r3_monotherapy",
      "description": "Monotherapy: HABTC+low/intermediate after 3-6 months lifestyle; OR age ≥80; OR frail. Class A/B/C/D low dose",
      "source": { "reference": "Hình 3", "page": 17 }
    },
    {
      "ruleId": "h3_r4_dual_combination",
      "description": "Dual combination: preferred A+C or A+D; alternatives A+B, B+C, B+D, C+D. Low → usual dose",
      "source": { "reference": "Hình 3", "page": 17 }
    },
    {
      "ruleId": "h3_r5_triple_combination",
      "description": "Triple combination: preferred A+C+D, usual dose",
      "source": { "reference": "Hình 3", "page": 17 }
    },
    {
      "ruleId": "h3_r6_resistant",
      "description": "Resistant (khó kiểm soát): on A+C+D at usual dose ≥1 month and not at target → REFER_SPECIALIST",
      "source": { "reference": "Hình 3", "page": 17 }
    }
